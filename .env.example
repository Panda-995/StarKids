# =============================================================================
# StarKids 环境变量配置
# =============================================================================

# ── 应用 ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=StarKids

# ── 数据库 ────────────────────────────────────────────────────────────────────
# 本地开发 (SQLite)
DATABASE_URL="file:./dev.db"

# Docker 部署 (PostgreSQL)
# DATABASE_URL="postgresql://starkids:starkids@localhost:5432/starkids"
# DIRECT_DATABASE_URL="postgresql://starkids:starkids@localhost:5432/starkids"

# ── 认证 (Auth.js v5) ─────────────────────────────────────────────────────────
AUTH_SECRET="替换为随机字符串 (npx auth secret 生成)"
AUTH_URL="${NEXT_PUBLIC_APP_URL}"

# ── 邮件 (Resend / SMTP) ───────────────────────────────────────────────────────
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="re_xxxxxxxx"
EMAIL_FROM="StarKids <noreply@starkids.app>"

# ── 文件上传 ──────────────────────────────────────────────────────────────────
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_SIZE_MB=10
SHARP_QUALITY=80
SHARP_WIDTH=1200

# ── Redis (Upstash / 本地) ────────────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# ── 文件存储 (可选) ───────────────────────────────────────────────────────────
# UPLOADTHING_SECRET="sk_xxxxxxxx"
# UPLOADTHING_APP_ID="xxxxxx"
